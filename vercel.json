{
  "version": 2,
  "functions": {
    "api/main.py": {
      "excludeFiles": "{venv/**,tests/**,.git/**,.pytest_cache/**,**/__pycache__/**,test_*.py}",
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/main.py"
    },
    {
      "src": "/static/(.*)",
      "dest": "frontend/$1"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/index.html"
    }
  ]
}
